# === Supabase (рекомендуется — 500MB бесплатно) ===
# Pooled (6543) — для приложения, Direct (5432) — для миграций
# Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

# === Railway ($5 бесплатно) ===
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/railway"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/railway"

# === Локальный PostgreSQL ===
# DATABASE_URL="postgresql://postgres:password@localhost:5432/money_budget"
# DIRECT_URL="postgresql://postgres:password@localhost:5432/money_budget"

# === Обязательные ===
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
TELEGRAM_BOT_TOKEN="your-bot-token"
# В production обязателен: тот же секрет в setWebHook и заголовке X-Telegram-Bot-Api-Secret-Token
# На Render допустимо и имя telegram_webhook_secret (нижний регистр) — бэкенд читает оба варианта
TELEGRAM_WEBHOOK_SECRET="random-long-string-for-webhook"

# === Опционально ===
PORT=3001
NODE_ENV=development
OPENAI_API_KEY="sk-..."
# Голос (Whisper) + чат «Помощник» (Llama через Groq) — один ключ
GROQ_API_KEY="..."
MINI_APP_URL="https://your-domain.com"
BACKEND_URL="https://your-backend.onrender.com"
# Дополнительные Origin для CORS в production (через запятую), если фронт на нескольких доменах
# CORS_EXTRA_ORIGINS="https://preview.vercel.app"
