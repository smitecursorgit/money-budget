generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

// Supabase: DATABASE_URL = pooled (6543), DIRECT_URL = direct (5432)
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(cuid())
  telegramId         BigInt    @unique @map("telegram_id")
  username           String?
  firstName          String?   @map("first_name")
  lastName           String?   @map("last_name")
  currency           String    @default("RUB")
  timezone           String    @default("Europe/Moscow")
  periodStart        Int       @default(1) @map("period_start")
  currentBudgetId    String?   @map("current_budget_id")
  trialStart         DateTime? @map("trial_start")
  subscriptionEndsAt DateTime? @map("subscription_ends_at")
  subscriptionExempt Boolean   @default(false) @map("subscription_exempt")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  currentBudget   Budget?   @relation("UserCurrentBudget", fields: [currentBudgetId], references: [id], onDelete: SetNull)
  budgets         Budget[]  @relation("UserBudgets")

  categories                 Category[]
  transactions               Transaction[]
  reminders                  Reminder[]
  yookassaProcessedPayments  YookassaProcessedPayment[]

  @@map("users")
}

model YookassaProcessedPayment {
  paymentId String   @id @map("payment_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("yookassa_processed_payments")
}

model Budget {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  name           String
  initialBalance Decimal  @default(0) @db.Decimal(12, 2) @map("initial_balance")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user              User         @relation("UserBudgets", fields: [userId], references: [id], onDelete: Cascade)
  usersCurrent      User[]       @relation("UserCurrentBudget")
  categories        Category[]
  transactions      Transaction[]
  reminders         Reminder[]

  @@index([userId])
  @@map("budgets")
}

model Category {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  budgetId  String?  @map("budget_id")
  name      String
  type      CategoryType
  keywords  String[]
  icon      String   @default("💰")
  color     String   @default("#6C63FF")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budget   Budget?  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([budgetId])
  @@map("categories")
}

model Transaction {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  budgetId   String?         @map("budget_id")
  categoryId String?         @map("category_id")
  amount     Decimal         @db.Decimal(12, 2)
  type       TransactionType
  date       DateTime        @default(now())
  note       String?
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budget   Budget?  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, type, date])
  @@index([budgetId, date])
  @@map("transactions")
}

model Reminder {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  budgetId   String?        @map("budget_id")
  title      String
  amount     Decimal?       @db.Decimal(12, 2)
  recurrence RecurrenceType
  nextDate   DateTime      @map("next_date")
  isActive   Boolean        @default(true) @map("is_active")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  budget Budget? @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([userId, nextDate])
  @@index([budgetId, nextDate])
  @@map("reminders")
}

enum CategoryType {
  income
  expense
}

enum TransactionType {
  income
  expense
}

enum RecurrenceType {
  once
  daily
  weekly
  monthly
  yearly
}
